{
  "author": "Robert Smieja",
  "bugs": "https://github.com/robbot-discord/winston-discordjs/issues",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "logform": "^2.7.0",
    "utility-types": "^3.11.0",
    "winston-transport": "^4.9.0"
  },
  "peerDependencies": {
    "discord.js": "^13.8.1"
  },
  "description": "Winston Transport using Discord.js",
  "devDependencies": {
    "@babel/core": "^7.18.13",
    "@babel/preset-env": "^7.18.10",
    "@babel/preset-typescript": "^7.18.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^5.36.0",
    "@typescript-eslint/parser": "^5.36.0",
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^27.0.1",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "nodejs",
    "winston",
    "discord",
    "logging",
    "log",
    "transport"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "winston-discordjs",
  "private": false,
  "repository": "https://github.com/robertsmieja/winston-discordjs",
  "scripts": {
    "build": "npm-run-all --parallel build:js lint",
    "build:js": "tsc",
    "clean": "rimraf dist/",
    "check": "npm-run-all --parallel lint typecheck",
    "lint": "eslint ./src/**/*",
    "lint:fix": "eslint --fix ./src/**/*",
    "lint:staged": "lint-staged",
    "postversion": "git push && git push --tags",
    "prepack": "npm-run-all clean build",
    "prepublishOnly": "npm-run-all --parallel test lint",
    "prettier": "prettier --write '*.{js,ts,jsx,tsx,json,md}'",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "version": "npm run lint:fix && git add -A src",
    "prepare": "husky install"
  },
  "types": "dist/index.d.ts",
  "version": "4.0.1"
}
