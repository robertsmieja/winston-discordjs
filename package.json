{
  "author": "Robert Smieja",
  "bugs": "https://github.com/robbot-discord/winston-discordjs/issues",
  "dependencies": {
    "@types/ws": "^8.18.1",
    "logform": "^2.7.0",
    "utility-types": "^3.11.0",
    "winston-transport": "^4.9.0"
  },
  "peerDependencies": {
    "discord.js": "^13.8.1"
  },
  "description": "Winston Transport using Discord.js",
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^5.36.0",
    "@typescript-eslint/parser": "^5.36.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.4",
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^8.0.1",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "nodejs",
    "winston",
    "discord",
    "logging",
    "log",
    "transport"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "winston-discordjs",
  "private": false,
  "repository": "https://github.com/robertsmieja/winston-discordjs",
  "scripts": {
    "build": "npm-run-all --parallel build:js build:types lint",
    "build:js": "esbuild src/index.ts --bundle --packages=external --platform=node --target=node20 --format=cjs --outdir=dist",
    "build:types": "tsc --emitDeclarationOnly",
    "clean": "rimraf dist/",
    "check": "npm-run-all --parallel lint typecheck",
    "lint": "eslint ./src/**/*",
    "lint:fix": "eslint --fix ./src/**/*",
    "lint:staged": "lint-staged",
    "postversion": "git push && git push --tags",
    "prepack": "npm-run-all clean build",
    "prepublishOnly": "npm-run-all --parallel test lint",
    "prettier": "prettier --write '*.{js,ts,jsx,tsx,json,md}'",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "version": "npm run lint:fix && git add -A src",
    "prepare": "husky install"
  },
  "types": "dist/index.d.ts",
  "version": "4.0.1"
}
